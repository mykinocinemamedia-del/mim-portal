// MIM Portal - Prisma Schema
// Compatible with both SQLite (local dev) and PostgreSQL (Supabase production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ====================================
// Users & Auth
// ====================================

model Helper {
  id              String   @id @default(cuid())
  userId          String?  @unique
  fullName        String
  nickname        String?
  ic              String?
  age             Int?
  birthDate       DateTime?
  religion        String?
  maritalStatus   String?
  education       String?
  phone           String?
  familyPhone     String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  postalCode      String?
  country         String?  @default("Malaysia")
  residencyState  String?
  workArea        String?
  canRelocate     Boolean  @default(false)
  serviceType     String?  // Pembantu Rumah, Pengasuh, Penjaga Orang Tua
  liveIn          Boolean  @default(false)
  backAndForth    Boolean  @default(false)
  canBoth         Boolean  @default(false)
  desiredJob      String?
  skills          String?  // JSON array as string
  childAges       String?  // JSON array as string
  otherSkills     String?
  motivation      String?
  experience      String?
  profilePhoto    String?
  email           String?  @unique
  password        String?
  isFirstLogin    Boolean  @default(true)
  rating          Float    @default(5.0)
  status          String   @default("pending") // pending, active, matched, employed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings         Booking[]
  schedules        Schedule[]
  contracts        Contract[]
  payments         Payment[]
  medicalRecords   MedicalRecord[]
  interviews       Interview[]
  helperNotifications Notification[] @relation("HelperNotifications")
  helperMessages      Message[]      @relation("HelperMessages")
  matchScores         MatchScore[]

  @@map("mim_helpers")
}

model Employer {
  id              String   @id @default(cuid())
  userId          String?  @unique
  fullName        String
  ic              String?
  phone           String?
  email           String?  @unique
  password        String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  postalCode      String?
  country         String?  @default("Malaysia")
  serviceType     String?
  numKids         Int      @default(0)
  kidsAges        String?
  salaryOffered   Float?
  joinDate        DateTime?
  criteria        String?
  contractExpiry  DateTime?
  profileData     String?  // JSON as string
  isFirstLogin    Boolean  @default(true)
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings         Booking[]
  schedules        Schedule[]
  contracts        Contract[]
  payments         Payment[]
  interviews       Interview[]
  employerNotifications Notification[] @relation("EmployerNotifications")
  employerMessages      Message[]      @relation("EmployerMessages")
  matchScores         MatchScore[]

  @@map("mim_employers")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  fullName  String?
  role      String   @default("admin")
  createdAt DateTime @default(now())

  @@map("mim_admins")
}

// ====================================
// Booking & Matching
// ====================================

model Booking {
  id              String   @id @default(cuid())
  employer        Employer @relation(fields: [employerId], references: [id])
  employerId      String
  helper          Helper   @relation(fields: [helperId], references: [id])
  helperId        String
  serviceType     String?
  salary          Float?
  startDate       DateTime?
  durationMonths  Int?
  liveIn          Boolean  @default(false)
  specialRequests String?
  status          String   @default("pending") // pending, confirmed, rejected, completed
  adminNotes      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contracts       Contract[]

  @@map("mim_bookings")
}

model Contract {
  id              String   @id @default(cuid())
  booking         Booking? @relation(fields: [bookingId], references: [id])
  bookingId       String?
  contractType    String   // agency_helper, agency_employer, employer_helper
  helper          Helper?  @relation(fields: [helperId], references: [id])
  helperId        String?
  employer        Employer? @relation(fields: [employerId], references: [id])
  employerId      String?
  content         String?
  pdfUrl          String?
  signedHelper    Boolean  @default(false)
  signedEmployer  Boolean  @default(false)
  signedAdmin     Boolean  @default(false)
  status          String   @default("draft")
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("mim_contracts")
}

// ====================================
// Operations
// ====================================

model Schedule {
  id          String   @id @default(cuid())
  helper      Helper   @relation(fields: [helperId], references: [id])
  helperId    String
  employer    Employer? @relation(fields: [employerId], references: [id])
  employerId  String?
  workDate    DateTime
  startTime   String?
  endTime     String?
  isDayOff    Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  @@map("mim_schedules")
}

model Payment {
  id          String   @id @default(cuid())
  employer    Employer @relation(fields: [employerId], references: [id])
  employerId  String
  helper      Helper?  @relation(fields: [helperId], references: [id])
  helperId    String?
  amount      Float
  dueDate     DateTime?
  paidDate    DateTime?
  status      String   @default("pending") // pending, paid, overdue
  method      String?
  notes       String?
  createdAt   DateTime @default(now())

  @@map("mim_payments")
}

model VideoCourse {
  id               String   @id @default(cuid())
  title            String
  description      String?
  videoUrl         String
  thumbnail        String?
  category         String?
  durationMinutes  Int?
  isPublished      Boolean  @default(true)
  createdAt        DateTime @default(now())

  progress         CourseProgress[]

  @@map("mim_video_courses")
}

model CourseProgress {
  id              String   @id @default(cuid())
  userId          String
  userType        String   // helper, employer
  course          VideoCourse @relation(fields: [courseId], references: [id])
  courseId        String
  watchedPercent  Int      @default(0)
  completed       Boolean  @default(false)
  lastWatchedAt   DateTime?
  createdAt       DateTime @default(now())

  @@unique([userId, courseId])
  @@map("mim_course_progress")
}

model Document {
  id          String   @id @default(cuid())
  title       String
  docType     String?  // faq, price, process, contract, medical
  content     String?
  fileUrl     String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("mim_documents")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  userType    String   // helper, employer
  helper      Helper?  @relation("HelperNotifications", fields: [helperId], references: [id])
  helperId    String?
  employer    Employer? @relation("EmployerNotifications", fields: [employerId], references: [id])
  employerId  String?
  title       String
  message     String?
  isRead      Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())

  @@map("mim_notifications")
}

model Interview {
  id          String   @id @default(cuid())
  helper      Helper?  @relation(fields: [helperId], references: [id])
  helperId    String?
  employer    Employer? @relation(fields: [employerId], references: [id])
  employerId  String?
  meetUrl     String?
  recordingUrl String?
  scheduledAt DateTime?
  status      String   @default("scheduled")
  notes       String?
  createdAt   DateTime @default(now())

  @@map("mim_interviews")
}

model Message {
  id          String   @id @default(cuid())
  fromAdmin   Boolean  @default(true)
  helper      Helper?  @relation("HelperMessages", fields: [helperId], references: [id])
  helperId    String?
  employer    Employer? @relation("EmployerMessages", fields: [employerId], references: [id])
  employerId  String?
  subject     String?
  body        String
  sentVia     String   @default("in_app")
  createdAt   DateTime @default(now())

  @@map("mim_messages")
}

model MedicalRecord {
  id          String   @id @default(cuid())
  helper      Helper   @relation(fields: [helperId], references: [id])
  helperId    String
  recordType  String?  // medical_health, vaccination
  result      String?
  fileUrl     String?
  notes       String?
  uploadDate  DateTime?
  createdAt   DateTime @default(now())

  @@map("mim_medical_records")
}

// ====================================
// AGENTIC AI SYSTEM TABLES
// ====================================

model Agent {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String
  description   String?
  category      String   // lead_gen, onboarding, matching, contract, operations, support, orchestrator
  status        String   @default("idle") // idle, running, paused, error
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  schedule      String?  // cron expression or interval
  config        String?  // JSON config
  totalRuns     Int      @default(0)
  successCount  Int      @default(0)
  errorCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activities    AgentActivity[]
  leads         Lead[]
  conversations Conversation[]
  matchScores   MatchScore[]
  referrals     Referral[]
  contentQueue  ContentQueue[]
  feedback      Feedback[]
  agentMessages AgentMessage[]

  @@map("mim_agents")
}

model AgentActivity {
  id          String   @id @default(cuid())
  agent       Agent    @relation(fields: [agentId], references: [id])
  agentId     String
  action      String   // e.g., "scan_facebook", "send_whatsapp", "generate_contract"
  status      String   // success, error, pending
  input       String?  // JSON input
  output      String?  // JSON output
  errorMessage String?
  duration    Int?     // milliseconds
  createdAt   DateTime @default(now())

  @@map("mim_agent_activities")
}

model Lead {
  id            String   @id @default(cuid())
  agent         Agent?   @relation(fields: [agentId], references: [id])
  agentId       String?
  leadType      String   // helper, employer
  source        String   // facebook, referral, content, ads, manual
  sourceUrl     String?
  contactName   String?
  contactPhone  String?
  contactEmail  String?
  profileData   String?  // JSON: scraped profile info
  status        String   @default("new") // new, contacted, qualified, converted, rejected
  score         Float?   // AI quality score 0-100
  notes         String?
  convertedTo   String?  // helper_id or employer_id if converted
  contactedAt   DateTime?
  qualifiedAt   DateTime?
  convertedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("mim_leads")
}

model Conversation {
  id          String   @id @default(cuid())
  agent       Agent?   @relation(fields: [agentId], references: [id])
  agentId     String?
  userId      String   // helper_id, employer_id, or lead_id
  userType    String   // helper, employer, lead
  channel     String   @default("whatsapp") // whatsapp, web, in_app
  status      String   @default("active") // active, completed, escalated, abandoned
  context     String?  // JSON: conversation context/state
  summary     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    AgentMessage[]

  @@map("mim_conversations")
}

model AgentMessage {
  id              String   @id @default(cuid())
  conversation    Conversation? @relation(fields: [conversationId], references: [id])
  conversationId  String?
  agent           Agent?   @relation(fields: [agentId], references: [id])
  agentId         String?
  sender          String   // user, agent, system
  content         String
  messageType     String   @default("text") // text, image, template, button
  metadata        String?  // JSON
  createdAt       DateTime @default(now())

  @@map("mim_agent_messages")
}

model MatchScore {
  id          String   @id @default(cuid())
  agent       Agent?   @relation(fields: [agentId], references: [id])
  agentId     String?
  helper      Helper   @relation(fields: [helperId], references: [id])
  helperId    String
  employer    Employer @relation(fields: [employerId], references: [id])
  employerId  String
  score       Float    // 0-100 compatibility score
  reasoning   String?  // AI explanation
  factors     String?  // JSON: breakdown of scoring factors
  status      String   @default("suggested") // suggested, viewed, accepted, rejected, matched
  createdAt   DateTime @default(now())

  @@unique([helperId, employerId])
  @@map("mim_match_scores")
}

model Referral {
  id            String   @id @default(cuid())
  agent         Agent?   @relation(fields: [agentId], references: [id])
  agentId       String?
  referrerType  String   // helper, employer
  referrerId    String
  referrerName  String
  referrerPhone String
  referredName  String
  referredPhone String
  referredEmail String?
  status        String   @default("pending") // pending, contacted, converted, rejected
  rewardType    String?  // cash, discount, voucher
  rewardAmount  Float?
  rewardStatus  String?  // pending, paid
  convertedAt   DateTime?
  createdAt     DateTime @default(now())

  @@map("mim_referrals")
}

model ContentQueue {
  id          String   @id @default(cuid())
  agent       Agent?   @relation(fields: [agentId], references: [id])
  agentId     String?
  platform    String   // facebook, instagram, tiktok, twitter, blog
  contentType String   // post, story, reel, article
  title       String?
  content     String
  hashtags    String?
  mediaUrl    String?
  scheduledAt DateTime?
  postedAt    DateTime?
  status      String   @default("draft") // draft, scheduled, posted, failed
  metrics     String?  // JSON: likes, shares, comments, reach
  createdAt   DateTime @default(now())

  @@map("mim_content_queue")
}

model Feedback {
  id          String   @id @default(cuid())
  agent       Agent?   @relation(fields: [agentId], references: [id])
  agentId     String?
  userId      String
  userType    String   // helper, employer
  feedbackType String  // week_1, month_1, quarterly, ad_hoc
  rating      Int      // 1-5
  category    String?  // satisfaction, issue, suggestion, complaint
  comments    String?
  sentiment   String?  // positive, neutral, negative
  actionTaken String?  // AI recommended action
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@map("mim_feedback")
}

model AgentNotification {
  id          String   @id @default(cuid())
  agentName   String?
  category    String   // match, lead, payment, contract, alert, summary
  severity    String   @default("info") // info, warning, critical
  title       String
  message     String
  actionUrl   String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("mim_agent_notifications")
}

